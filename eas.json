{
  "cli": {
    "version": ">= 18.8.1",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal"
    },
    "preview": {
      "distribution": "internal"
    },
    "production": {
      "autoIncrement": true,
      "env": {
        "EXPO_PUBLIC_API_URL": "https://api.rule-auto.uz/api",
        "EXPO_PUBLIC_FILE_URL": "https://api.rule-auto.uz"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
